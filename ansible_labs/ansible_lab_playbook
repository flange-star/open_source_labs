---
- name: Ansible Lab Playbook
  hosts: managed
  become: yes

  tasks:
    - name: Install curl
      apt:
        name: curl
        state: present

    - name: Create a test file
      copy:
        content: "THE ONE PIECE IS REAL!\n"
        dest: /home/your_mint_username/ansible_test.txt

    - name: Filter and Check system memory
      ansible.builtin.setup
      filter:
        - 'ansible_*_mb'
